{
    "name": "@plurid/deon",
    "version": "0.0.0-11",
    "description": "DeObject Notation Format of Structured Strings",
    "keywords": [
        "deon"
    ],
    "author": "ly3xqhl8g9 <ly3xqhl8g9@plurid.com> (https://plurid.com)",
    "license": "SEE LICENSE IN LICENSE",
    "repository": {
        "type": "git",
        "url": "https://github.com/plurid/deon"
    },
    "bugs": {
        "email": "source@plurid.com",
        "url": "https://github.com/plurid/deon/issues"
    },
    "homepage": "https://github.com/plurid/deon/tree/master/packages/deon-javascript/README.md",
    "publishConfig": {
        "registry": "https://registry.npmjs.org/",
        "access": "public"
    },
    "engines": {
        "node": ">=20"
    },
    "main": "distribution/index.cjs",
    "module": "distribution/index.mjs",
    "typings": "distribution/index.d.ts",
    "exports": {
        ".": {
            "types": "./distribution/index.d.ts",
            "import": "./distribution/index.mjs",
            "require": "./distribution/index.cjs"
        },
        "./pure": {
            "types": "./distribution/pure.d.ts",
            "import": "./distribution/pure.mjs",
            "require": "./distribution/pure.cjs"
        },
        "./package.json": "./package.json"
    },
    "bin": {
        "deon": "binder/deon"
    },
    "files": [
        "distribution",
        "binder"
    ],
    "preferGlobal": false,
    "scripts": {
        "build": "node scripts/clean.mjs && tsc -p tsconfig.build.json && rollup -c scripts/rollup.config.mjs && node scripts/smoke.mjs",
        "build:bundle": "rollup -c scripts/rollup.config.mjs",
        "build:compile": "tsc -p tsconfig.build.json",
        "build:production": "node scripts/clean.mjs && tsc -p tsconfig.build.json && rollup -c scripts/rollup.config.mjs && node scripts/smoke.mjs",
        "clean": "node scripts/clean.mjs",
        "lint": "tsc -p tsconfig.json --noEmit",
        "test": "node scripts/clean-tests.mjs && tsc -p tsconfig.test.json && node scripts/test.mjs",
        "test:compile": "node scripts/clean-tests.mjs && tsc -p tsconfig.test.json",
        "test:suite": "node scripts/clean-tests.mjs && tsc -p tsconfig.test.json && node scripts/test.mjs",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "watch": "node scripts/watch.mjs",
        "prepublishOnly": "node scripts/clean.mjs && tsc -p tsconfig.build.json && rollup -c scripts/rollup.config.mjs && node scripts/smoke.mjs"
    },
    "devDependencies": {
        "@types/node": "^26.1.1",
        "rollup": "^4.62.2",
        "typescript": "^7.0.2"
    }
}

{
    "name": "@plurid/deon-mcp",
    "version": "0.0.0-1",
    "description": "Deon over the Model Context Protocol: a validator, and a prompt library, for a model that writes Deon",
    "license": "DEL",
    "homepage": "https://github.com/plurid/deon",
    "repository": "https://github.com/plurid/deon",
    "type": "module",
    "main": "distribution/index.js",
    "types": "distribution/index.d.ts",
    "exports": {
        ".": {
            "types": "./distribution/index.d.ts",
            "import": "./distribution/index.js"
        }
    },
    "bin": {
        "deon-mcp": "distribution/cli.js"
    },
    "files": [
        "distribution"
    ],
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "test": "npm run build && node --test tests/*.test.js",
        "start": "node distribution/cli.js"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@plurid/deon": "file:../../deon-javascript",
        "zod": "^3.25.0"
    },
    "devDependencies": {
        "@types/node": "^22",
        "typescript": "^5.6.0"
    }
}

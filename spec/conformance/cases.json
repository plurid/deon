        {
            "id": "unquoted-keeps-an-interior-single-quote",
            "required": true,
            "source": "{ a x'q'y }",
            "expected": { "a": "x'q'y" },
            "canonical": "{\n    a 'x\\'q\\'y'\n}\n"
        },
